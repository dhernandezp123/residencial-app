NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required only for server-side admin operations, cron jobs, notifications, and gate access registration.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Required in production for /api/cron/* endpoints. Vercel Cron sends it as Authorization: Bearer $CRON_SECRET.
CRON_SECRET=your-random-cron-secret

# Required only for web push notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
INTERNAL_PUSH_SECRET=your-random-internal-push-secret
